# Discord bot credentials (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: set for instant command registration to a single test server.
# Leave blank to register commands globally (can take up to an hour to propagate).
DISCORD_DEV_GUILD_ID=

# API-Football / api-sports.io key (https://www.api-football.com)
FOOTBALL_API_KEY=
FOOTBALL_API_HOST=v3.football.api-sports.io

# How often (seconds) the live-match poller checks for new events.
# Keep this high on free API tiers (100 req/day) to avoid rate limiting.
LIVE_POLL_INTERVAL_SECONDS=60

# Fallback timezone used when a user/server has not set one (IANA name).
DEFAULT_TIMEZONE=UTC

# Current football season year used for standings/stats endpoints, e.g. 2024
FOOTBALL_SEASON=2024
